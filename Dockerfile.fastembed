FROM python:3.11-slim

WORKDIR /app

# Install dependencies required by fastembed
RUN pip install --no-cache-dir fastembed flask

# Copy the server script
COPY scripts/embeddings_server.py .

# Pre-download the default model during build time so it doesn't happen on every startup
ENV DEFAULT_MODEL="BAAI/bge-small-en-v1.5"
RUN python3 -c "from fastembed import TextEmbedding; TextEmbedding('$DEFAULT_MODEL')"

EXPOSE 11434

# Ensure unbuffered output for standard python logging
ENV PYTHONUNBUFFERED=1

CMD ["python", "embeddings_server.py", "--port", "11434", "--model", "BAAI/bge-small-en-v1.5"]
